      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.tree import DecisionTreeClassifier, plot_tree\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# -----------------------------\n",
        "# STEP 1: CREATE SYNTHETIC DATA\n",
        "# -----------------------------\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    \"study_hours\": np.random.randint(1, 10, 15), #randint(start_value, end_value, number_of_values)\n",
        "    \"attendance\": np.random.randint(50, 100, 15),\n",
        "    \"previous_score\": np.random.randint(40, 100, 15)\n",
        "})\n",
        "\n",
        "# RULE to generate target (what model learns)\n",
        "df[\"pass\"] = (\n",
        "    (df[\"study_hours\"] > 5).astype(int) +\n",
        "    (df[\"attendance\"] > 75).astype(int) +\n",
        "    (df[\"previous_score\"] > 60).astype(int)\n",
        ")\n",
        "\n",
        "df[\"pass\"] = (df[\"pass\"] >= 2).astype(int)\n",
        "\n",
        "print(\"\\nSYNTHETIC DATASET\")\n",
        "print(df)"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#Branches?- Study_hours, attendance, previous_score.-- most important branch- ROOT\n",
        "#Leaf? - Pass"
      ],
      "metadata": {
        "id": "iUpkioYViRde"
      },
      "execution_count": 2,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# -----------------------------\n",
        "# STEP 2: TRAIN MODEL\n",
        "# -----------------------------\n",
        "\n",
        "X = df[[\"study_hours\", \"attendance\", \"previous_score\"]]\n",
        "y = df[\"pass\"]\n",
        "\n",
        "model = DecisionTreeClassifier(max_depth=3, random_state=42)\n",
        "model.fit(X, y)\n",
        "\n",
        "print(\"\\n Decision Tree Model Trained Successfully!\")"
      ],
      "metadata": {
